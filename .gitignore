# ──────────────────────────────────────────────
# JavaScript / TypeScript / Node.js
# ──────────────────────────────────────────────
node_modules/
dist/
build/
.next/
.nuxt/
out/
.turbo/
.cache/
*.tsbuildinfo

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/
env/
.python-version

# ──────────────────────────────────────────────
# .NET / C#
# ──────────────────────────────────────────────
bin/
obj/
*.user
.vs/
*.suo
*.userprefs

# ──────────────────────────────────────────────
# Java
# ──────────────────────────────────────────────
target/
.gradle/
*.class
*.jar
*.war
*.ear
.mvn/timing.properties

# ──────────────────────────────────────────────
# Secrets — never commit these
# ──────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.cer
*.p12
*.jks
secrets.*
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.secret
appsettings.Production.json
appsettings.Staging.json

# ──────────────────────────────────────────────
# VS Code local state (keep settings, tasks, extensions)
# ──────────────────────────────────────────────
.vscode/*.log

# ──────────────────────────────────────────────
# AI workflow logs — ignore content, keep directory
# The .gitkeep files are tracked; logs are not.
# ──────────────────────────────────────────────
.ai-workflows/logs/*.log
.ai-workflows/logs/*.json
.ai-workflows/logs/*.md
!.ai-workflows/logs/.gitkeep

# SDD changes are important artifacts — DO NOT ignore them
# .ai-workflows/sdd/changes/ is intentionally tracked
!.ai-workflows/sdd/changes/
!.ai-workflows/sdd/changes/.gitkeep

# ──────────────────────────────────────────────
# OS-generated files
# ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ──────────────────────────────────────────────
# Editor files
# ──────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
*.iml
*.iws
*.ipr
